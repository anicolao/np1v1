{
  "name": "np1v1",
  "version": "0.1.0",
  "description": "A turn-based 1v1 league and tournament system designed for competitive gameplay with automated game management, player ratings, and Discord integration.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "verify": "npm run build && node dist/verify.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "discord",
    "bot",
    "tournament",
    "league",
    "1v1",
    "gaming"
  ],
  "author": "",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "discord.js": "^14.14.0",
    "dotenv": "^16.3.0",
    "mongodb": "^6.3.0",
    "node-cron": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
